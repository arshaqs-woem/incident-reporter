{
  "version": 2,
  "routes": [
    { "src": "/api/webhook/answer",          "dest": "/api/webhook/answer.js" },
    { "src": "/api/webhook/events",           "dest": "/api/webhook/events.js" },
    { "src": "/api/calls/([^/]+)/summary",    "dest": "/api/calls/[id].js?id=$1&summary=1" },
    { "src": "/api/calls/([^/]+)",            "dest": "/api/calls/[id].js?id=$1" },
    { "src": "/api/calls",                    "dest": "/api/calls/index.js" },
    { "src": "/api/tools/debug-headers",      "dest": "/api/tools/debug-headers.js" },
    { "src": "/api/tools/report-incident",    "dest": "/api/tools/report-incident.js" },
    { "src": "/api/incidents",                 "dest": "/api/incidents.js" },
    { "src": "/api/follow-ups",               "dest": "/api/follow-ups.js" },
    { "src": "/api/analytics",                "dest": "/api/analytics.js" },
    { "src": "/api/health",                   "dest": "/api/health.js" }
  ]
}
